# SPLUNK-BOT deployment credentials
# Copy to .env and fill in values — NEVER commit .env

# === Key-based SSH (default) ===
SSH_KEY=~/.ssh/id_ed25519
SSH_USER=dave
SSH_HOST=192.168.1.114
SSH_PORT=22
SPLUNK_HOME_REMOTE=/opt/splunk
SPLUNK_USER=admin
SPLUNK_PASS=changeme

# === Password-based SSH (QEMU VM mode) ===
# Uncomment and set SSH_PASS to use sshpass instead of key auth:
# SSH_PASS=splunk
# SSH_USER=splunk
# SSH_HOST=localhost
# SSH_PORT=2222
# SPLUNK_PASS=changeme123
